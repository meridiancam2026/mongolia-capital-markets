# Database
DATABASE_URL=postgresql+asyncpg://mongolia_user:your_password@localhost:5432/mongolia

# Redis
REDIS_URL=redis://localhost:6379

# Scraper settings
MSE_SCRAPER_INTERVAL_SECONDS=60
OTC_SCRAPER_HOUR=18
OTC_SCRAPER_MINUTE=30

# API keys (obtain from each provider — see DATA_SOURCES.md)
METRICON_API_KEY=placeholder
TRADING_ECONOMICS_API_KEY=placeholder
FLUENTAX_API_KEY=placeholder

# App settings
APP_ENV=development
LOG_LEVEL=INFO
