# Database
DATABASE_URL=postgresql+asyncpg://mongolia_user:your_password@localhost:5432/mongolia
DATABASE_SYNC_URL=postgresql+psycopg2://mongolia_user:your_password@localhost:5432/mongolia

# Redis
REDIS_URL=redis://localhost:6379

# Scraper settings
MSE_SCRAPER_INTERVAL_SECONDS=60
OTC_SCRAPER_HOUR=18
OTC_SCRAPER_MINUTE=30
BOM_SCRAPER_HOUR=8
BOM_SCRAPER_MINUTE=0

# API keys (obtain from each provider — see DATA_SOURCES.md)
METRICON_API_KEY=placeholder
TRADING_ECONOMICS_API_KEY=placeholder
FLUENTAX_API_KEY=placeholder

# Cbonds — bond market data (prices, yields)
CBONDS_USERNAME=placeholder
CBONDS_PASSWORD=placeholder

# Playwright — path to system Chromium (installed via snap on Ubuntu 26.04)
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/snap/bin/chromium

# App settings
APP_ENV=development
LOG_LEVEL=INFO
